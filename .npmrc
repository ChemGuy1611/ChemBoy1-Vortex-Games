# vortex-api (npm:@nexusmods/vortex-api) declares exact-version peerDependencies
# matching what Vortex ships at runtime (e.g. fs-extra@9.1.0). This repo only
# consumes the package for typings/intellisense — extensions run inside Vortex,
# which provides all runtime modules — so strict peer resolution would force
# pointless downgrades of our own dev tooling. Skip auto-installing peers.
legacy-peer-deps=true
